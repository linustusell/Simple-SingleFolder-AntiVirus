<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="com.tusell.ui.MainController" spacing="14.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" styleClass="app-root">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
    </padding>

    <Label styleClass="title-label" text="Antivirus Scanner" />
    <Label styleClass="subtitle-label" text="Escaneja carpetes, detecta fitxers sospitosos i envia amenaces a quarantena." />

    <HBox spacing="10.0" styleClass="card">
        <Label text="Carpeta:" />
        <TextField fx:id="scanPathField" HBox.hgrow="ALWAYS" promptText="Ruta de la carpeta a escanejar" />
        <Button fx:id="browseButton" onAction="#onBrowseFolder" text="Seleccionar carpeta" />
        <Button fx:id="scanButton" onAction="#onStartScan" text="Escanejar" />
    </HBox>

    <HBox spacing="18.0" styleClass="card">
        <Label fx:id="statusLabel" text="Estat: preparat" />
        <Label fx:id="threatsCountLabel" text="Amenaces detectades: 0" />
        <Button fx:id="openQuarantineButton" onAction="#onOpenQuarantine" text="Obrir quarantena" />
    </HBox>

    <VBox spacing="8.0" styleClass="card" VBox.vgrow="ALWAYS">
        <Label styleClass="section-title" text="Resultats de l'escaneig" />
        <TableView fx:id="threatsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="fileColumn" prefWidth="430.0" text="Fitxer" />
                <TableColumn fx:id="reasonsColumn" prefWidth="420.0" text="Motius" />
            </columns>
        </TableView>
    </VBox>
</VBox>
